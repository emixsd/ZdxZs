# ── ZapSign ───────────────────────────────────────────
ZAPSIGN_API_TOKEN=token
# Mesmo valor do header x-webhook-secret configurado no webhook da ZapSign
# (obrigatório — o app não sobe sem ele)
ZAPSIGN_WEBHOOK_SECRET=secret

# Produção: https://api.zapsign.com.br/api/v1
# Sandbox:  https://sandbox.api.zapsign.com.br/api/v1
ZAPSIGN_BASE_URL=https://sandbox.api.zapsign.com.br/api/v1

# Token do modelo DOCX 
ZAPSIGN_TEMPLATE_ID=a7ffc429-c4cc-4cf9-a7dc-a3a4416f018c
# URL pública do PDF (fallback)
ZAPSIGN_PDF_URL=
# Envio automatico por WhatsApp. Se falhar, o app tenta seguir por e-mail.
ZAPSIGN_SEND_AUTOMATIC_WHATSAPP=true

# ── Zendesk ──────────────────────────────────────────
ZENDESK_SUBDOMAIN=sua-empresa
ZENDESK_EMAIL=agente@empresa.com
ZENDESK_API_TOKEN=seu_token_zendesk

# ── Servidor ─────────────────────────────────────────
PORT=3000
WEBHOOK_SECRET=chave_para_validar_webhooks_zendesk

# ── Slack (opcional) ─────────────────────────────────
SLACK_WEBHOOK_URL=
